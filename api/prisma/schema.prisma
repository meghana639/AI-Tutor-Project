generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tutor {
  id              String @id @default(cuid())
  name            String
  initials        String
  subject         String
  rating          Float
  experienceYears Int
  totalStudents   Int
  overallScore    Int
  email           String @unique
  bio             String
}